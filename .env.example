# Embedding provider: local | openai | noop
#   local  -> transformers.js MiniLM-L6-v2 (384d), no API key, downloads ~90MB on first run
#   openai -> requires OPENAI_API_KEY (text-embedding-3-small, sliced to EMBED_DIM)
#   noop   -> deterministic hash embedding (tests/CI, no network)
EMBEDDING_PROVIDER=local

# Path to the local SQLite database file (use :memory: for ephemeral)
HUB_DB_PATH=./data/hub.db

# Embedding dimension. Must match the provider's model. MiniLM-L6-v2 = 384.
# Changing this requires `npm run reindex`.
EMBED_DIM=384

# Hybrid search fusion weights (keyword vs vector). Must sum to ~1.
SEARCH_KEYWORD_WEIGHT=0.5
SEARCH_VECTOR_WEIGHT=0.5

# Optional: OpenAI key, only used when EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# --- Web app (Next.js) ---
# Session cookie signing key (HMAC). Set a long random value in production.
# AUTH_SECRET=change-me-to-a-long-random-string

# GitHub OAuth app credentials. When unset, the web app falls back to a local
# demo login (alice/bob/carol). Callback URL: <origin>/api/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Force-enable demo login even when GitHub OAuth is configured (1 = on).
# AUTH_ALLOW_DEV=1

# Comma-separated logins allowed on the /status admin page. When unset, any
# authenticated user is treated as an admin (dev convenience).
# ADMIN_LOGINS=alice,bob
